# =====================================================================
# 企业合规管理系统 - 环境配置模板
# Compliance Management System - Environment Configuration Template
# =====================================================================
# 使用方法:
#   1. 复制此文件为 .env
#   2. 根据实际环境修改以下配置
#   3. 切勿将真实的 .env 文件提交到版本控制
# =====================================================================

# ---------------------------------------------------------------------
# 应用配置
# ---------------------------------------------------------------------
APP_NAME=企业合规管理系统
APP_VERSION=1.0.0
DEBUG=false
ENV=production

# ---------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
# 支持数万员工每日数百万条数据的高并发场景
# ---------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/compliance_db
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=100

# ---------------------------------------------------------------------
# Redis 配置 (缓存 + 队列 + 分布式锁)
# ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100

# ---------------------------------------------------------------------
# Celery 任务队列配置
# ---------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------
# 安全配置
# ---------------------------------------------------------------------
SECRET_KEY=please-change-this-to-a-very-long-random-string-that-is-at-least-64-characters-long-and-includes-letters-numbers-and-symbols
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------
# 数据源: 邮件系统 (IMAP)
# ---------------------------------------------------------------------
MAIL_SERVER=imap.company.com
MAIL_PORT=993
MAIL_USERNAME=compliance_monitor@company.com
MAIL_PASSWORD=your_email_password_here
MAIL_USE_SSL=true

# ---------------------------------------------------------------------
# 数据源: 即时通讯 (企业微信/钉钉/飞书 Webhook)
# ---------------------------------------------------------------------
IM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
IM_WEBHOOK_TOKEN=your_im_token_here

# 管理层群聊 Webhook (重大违规实时推送)
MANAGEMENT_GROUP_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=management_group_key

# ---------------------------------------------------------------------
# 数据源: 门禁系统 API
# ---------------------------------------------------------------------
DOOR_ACCESS_API_URL=https://door-access.company.com/api/v1
DOOR_ACCESS_API_KEY=your_door_access_api_key_here

# ---------------------------------------------------------------------
# 数据源: 财务报销系统 API
# ---------------------------------------------------------------------
FINANCE_API_URL=https://finance.company.com/api/v1
FINANCE_API_KEY=your_finance_api_key_here

# ---------------------------------------------------------------------
# 数据采集性能配置
# ---------------------------------------------------------------------
DATA_COLLECTION_BATCH_SIZE=1000
DATA_PROCESSING_WORKERS=8

# ---------------------------------------------------------------------
# 文件输出路径
# ---------------------------------------------------------------------
REPORT_OUTPUT_DIR=./reports
EVIDENCE_PACKAGE_DIR=./evidence_packages

# ---------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
